---
import Container from "@components/Container.astro";
import { SITE } from "@consts";
import BackToTop from "@components/BackToTop.astro";
import ThemeToggle from "@components/ThemeToggle.astro";

const footerNameChars = SITE.NAME.split("");
---

<footer class="animate">
  <Container>
    <div class="relative">
      <div class="absolute right-0 -top-20">
        <BackToTop />
      </div>
    </div>
    <div class="flex justify-between items-center">
      <div>
        &copy; {new Date().getFullYear()}
        {"|"}
        <span
          id="footer-name-terminal"
          class="footer-name-terminal"
          aria-label={SITE.NAME}
        >
          {
            footerNameChars.map((char) => (
              <span
                class="footer-name-char"
                data-char={char}
                aria-hidden="true"
              >
                {char}
              </span>
            ))
          }
        </span>
      </div>
      <ThemeToggle />
    </div>
  </Container>
</footer>

<style>
  .footer-name-terminal {
    display: inline-block;
    margin-left: 0.3rem;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
    letter-spacing: 0.02em;
  }

  .footer-name-char {
    display: inline-flex;
    justify-content: center;
    align-items: baseline;
    line-height: inherit;
    white-space: pre;
  }

  .footer-name-char.is-scrambled {
    opacity: 0.55;
    font-family: "Silkscreen", cursive;
    font-size: 0.9em;
    line-height: inherit;
  }
</style>

<script>
  import {
    destroyFooterNameTerminal,
    initFooterNameTerminal,
  } from "@lib/footerNameTerminal";

  const run = () => initFooterNameTerminal();

  document.addEventListener("DOMContentLoaded", run);
  document.addEventListener("astro:after-swap", run);
  window.addEventListener("pagehide", destroyFooterNameTerminal);
  run();
</script>
