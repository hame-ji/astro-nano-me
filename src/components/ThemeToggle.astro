<div class="flex flex-wrap items-center gap-1" data-theme-toggle>
  <button
    aria-label="Light theme"
    class="group size-8 flex items-center justify-center rounded-full"
    data-theme-mode="light"
    type="button"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-colors duration-300 ease-in-out group-hover:stroke-black group-hover:dark:stroke-white"
    >
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
  </button>

  <button
    aria-label="Dark theme"
    class="group size-8 flex items-center justify-center rounded-full"
    data-theme-mode="dark"
    type="button"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-colors duration-300 ease-in-out group-hover:stroke-black group-hover:dark:stroke-white"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>

  <button
    aria-label="System theme"
    class="group size-8 flex items-center justify-center rounded-full"
    data-theme-mode="system"
    type="button"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-colors duration-300 ease-in-out group-hover:stroke-black group-hover:dark:stroke-white"
    >
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
      <line x1="8" y1="21" x2="16" y2="21"></line>
      <line x1="12" y1="17" x2="12" y2="21"></line>
    </svg>
  </button>
</div>

<script>
  import type { ThemeMode } from "@lib/theme/themeController";
  import { applyThemeMode } from "@lib/theme/themeController";
  import { playThemeSwitchSound } from "@lib/sound/themeSwitchAudio";

  function initThemeToggleSound() {
    const wrappers = document.querySelectorAll<HTMLElement>(
      "[data-theme-toggle]"
    );

    wrappers.forEach((wrapper) => {
      if (wrapper.dataset.toggleReady === "true") {
        return;
      }

      wrapper.dataset.toggleReady = "true";

      const buttons = wrapper.querySelectorAll<HTMLButtonElement>(
        "button[data-theme-mode]"
      );

      buttons.forEach((button) => {
        if (button.dataset.toggleBound === "true") {
          return;
        }

        button.dataset.toggleBound = "true";

        const applyModeFromGesture = async () => {
          const mode = button.dataset.themeMode as ThemeMode | undefined;

          if (mode === undefined) {
            return;
          }

          const { changed, nextDark } = applyThemeMode(mode);

          if (!changed) {
            return;
          }

          await playThemeSwitchSound(nextDark ? "off" : "on");
        };

        button.addEventListener("pointerdown", (event) => {
          if (event.button !== 0 || !event.isPrimary) {
            return;
          }

          button.dataset.suppressClick = "true";
          event.preventDefault();
          void applyModeFromGesture();
        });

        button.addEventListener("click", (event) => {
          if (button.dataset.suppressClick === "true") {
            button.dataset.suppressClick = "false";
            event.preventDefault();
            return;
          }

          void applyModeFromGesture();
        });
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initThemeToggleSound);
  document.addEventListener("astro:after-swap", initThemeToggleSound);
  initThemeToggleSound();
</script>
